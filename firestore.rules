rules_version = '2';

// ========================================
// Cloud Firestore セキュリティルール（Phase 1: アカウント基盤）
//
// 信頼境界の方針（合意済み）:
// - users/{uid} のプロフィール項目（表示名・アイコン・称号）は本人だけが書ける
// - 戦績・実績（Phase 2以降）は Cloud Functions（Admin SDK＝ルール非適用）
//   だけが書く。クライアントからの直接改ざんを構造的に防ぐため、
//   本人であってもクライアントからは書けないフィールドにする
// - 読み取りは認証済みユーザーなら誰でも可（フレンドのプロフィール表示等で使う）
// ========================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // 認証済み（ゲスト含む）なら誰のプロフィールも読める
      allow read: if request.auth != null;

      // 作成: 本人のみ。書けるフィールドはプロフィール項目に限定
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(
             ['displayName', 'selectedIcon', 'selectedTitle', 'createdAt'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 12;

      // 更新: 本人のみ。プロフィール項目と reactedFirstAt（対人リアクション初送信
      // の実績＝唯一のクライアント記録）だけ変更可。stats/achievements/counters
      // など戦績・実績本体は Functions のみ（クライアントからは変更不可）。
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['displayName', 'selectedIcon', 'selectedTitle', 'reactedFirstAt'])
        && (!('displayName' in request.resource.data.diff(resource.data).affectedKeys())
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() >= 1
                && request.resource.data.displayName.size() <= 12))
        && (!('reactedFirstAt' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.reactedFirstAt is number);

      allow delete: if false;

      // ★Phase 2★ 対局履歴（Cloud Functions のみが書く）。
      // 読み取りは本人だけ（Phase 4 の「直近一緒に遊んだ人」表示に使う）
      match /games/{gameId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ★Phase 2★ 戦績書き込みの冪等マーカー（Functions 専用・クライアント不可視）
    match /processedGames/{gameId} {
      allow read, write: if false;
    }

    // 上記以外はすべて拒否（Phase 2以降で必要になったら明示的に開ける）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
