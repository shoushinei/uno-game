rules_version = '2';

// ========================================
// Cloud Firestore セキュリティルール（Phase 1: アカウント基盤）
//
// 信頼境界の方針（合意済み）:
// - users/{uid} のプロフィール項目（表示名・アイコン・称号）は本人だけが書ける
// - 戦績・実績（Phase 2以降）は Cloud Functions（Admin SDK＝ルール非適用）
//   だけが書く。クライアントからの直接改ざんを構造的に防ぐため、
//   本人であってもクライアントからは書けないフィールドにする
// - 読み取りは認証済みユーザーなら誰でも可（フレンドのプロフィール表示等で使う）
// ========================================
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // 認証済み（ゲスト含む）なら誰のプロフィールも読める
      allow read: if request.auth != null;

      // 作成: 本人のみ。書けるフィールドはプロフィール項目に限定
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.keys().hasOnly(
             ['displayName', 'selectedIcon', 'selectedTitle', 'createdAt', 'friendCode'])
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() >= 1
        && request.resource.data.displayName.size() <= 12;

      // 更新: 本人のみ。プロフィール項目・reactedFirstAt（対人リアクション初送信
      // の実績＝唯一のクライアント記録）・friendCode（フレンドコード＝Phase 4）
      // だけ変更可。stats/achievements/counters など戦績・実績本体は
      // Functions のみ（クライアントからは変更不可）。
      allow update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['displayName', 'selectedIcon', 'selectedTitle', 'reactedFirstAt', 'friendCode'])
        && (!('displayName' in request.resource.data.diff(resource.data).affectedKeys())
            || (request.resource.data.displayName is string
                && request.resource.data.displayName.size() >= 1
                && request.resource.data.displayName.size() <= 12))
        && (!('reactedFirstAt' in request.resource.data.diff(resource.data).affectedKeys())
            || request.resource.data.reactedFirstAt is number);

      allow delete: if false;

      // ★Phase 2★ 対局履歴（Cloud Functions のみが書く）。
      // 読み取りは本人だけ（Phase 4 の「直近一緒に遊んだ人」表示に使う）
      match /games/{gameId} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow write: if false;
      }
    }

    // ★Phase 2★ 戦績書き込みの冪等マーカー（Functions 専用・クライアント不可視）
    match /processedGames/{gameId} {
      allow read, write: if false;
    }

    // ★Phase 4★ フレンドコード → uid の逆引き（コード入力で申請するため）。
    // get のみ許可（list は不可＝総当たり列挙を防ぐ）。本人のuidだけ登録可能。
    match /friendCodes/{code} {
      allow get: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly(['uid']);
      allow update, delete: if false;
    }

    // ★Phase 4★ フレンド関係（2人1組で1ドキュメント）。
    // pairId = sort([a,b]).join('_')。status: 'pending' → 'accepted'。
    // 承認制: 申請=create(pending) / 承認=update(accepted) / 拒否・取消・解除=delete。
    match /friendships/{pairId} {
      // get: 当事者のみ。ただし存在しないドキュメント(resource==null)は
      // 申請前の存在チェックのために取得を許す（中身は無い）
      allow get: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.members);
      // list（members array-contains 自分 のクエリ）: 当事者のみ
      allow list: if request.auth != null
        && request.auth.uid in resource.data.members;

      // 申請: 自分を含む2人・pending・requestedBy が自分
      allow create: if request.auth != null
        && request.resource.data.members is list
        && request.resource.data.members.size() == 2
        && request.auth.uid in request.resource.data.members
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending';

      // 承認: 申請の相手（requestedBy でない当事者）だけが pending→accepted に。
      // members / requestedBy は変更不可
      allow update: if request.auth != null
        && request.auth.uid in resource.data.members
        && request.auth.uid != resource.data.requestedBy
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.members == resource.data.members
        && request.resource.data.requestedBy == resource.data.requestedBy;

      // 拒否（相手）・取消（申請者）・フレンド解除（どちらか）: 当事者なら削除可
      allow delete: if request.auth != null
        && request.auth.uid in resource.data.members;
    }

    // ★バグ報告★ クライアントは「作成のみ可・読み取り不可」。
    // ユーザー間で報告は見えず改ざんもできない。開発者は Firebase コンソール
    // （Admin権限＝ルール非適用）で閲覧する。サイズ上限は bug-report-logic.ts と一致。
    match /bugReports/{id} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasOnly([
             'uid', 'name', 'roomId', 'uiMode', 'userAgent', 'description',
             'roomSnapshot', 'replay', 'recentErrors', 'truncated', 'createdAt'])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.description.size() >= 1
        && request.resource.data.description.size() <= 1000
        && request.resource.data.roomSnapshot is string
        && request.resource.data.roomSnapshot.size() <= 300000
        && request.resource.data.replay is string
        && request.resource.data.replay.size() <= 600000
        && request.resource.data.recentErrors is string
        && request.resource.data.recentErrors.size() <= 20000
        && request.resource.data.truncated is bool;
      allow read, update, delete: if false;
    }

    // 上記以外はすべて拒否（Phase 2以降で必要になったら明示的に開ける）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
